@startuml
title PitchPose Runtime Architecture (Simple)
left to right direction
skinparam componentStyle rectangle
skinparam shadowing false
skinparam defaultTextAlignment center

rectangle "Input Video\n(monocular clip)" as INPUT
rectangle "Runtime Pipeline\n(src/main.py)" as MAIN
rectangle "Pose Estimation\n(MediaPipe Pose)" as POSE
rectangle "Scan Detection\n(V1 / V2 / V3)" as SCAN
rectangle "Outputs\nOverlay / Stickman / CSV" as OUT
rectangle "Interactive Viewer\n(Qualitative Analysis)" as VIEWER

INPUT --> MAIN
MAIN --> POSE
POSE --> SCAN
SCAN --> OUT
OUT --> VIEWER

@enduml
